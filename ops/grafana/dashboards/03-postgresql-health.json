    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "description": "Эффективность кэша PostgreSQL. Целевой коридор обычно >95-99%.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
