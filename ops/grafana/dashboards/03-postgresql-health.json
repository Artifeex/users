          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-main"
          },
          "editorMode": "code",
          "expr": "sum(rate(pg_stat_database_blks_hit{instance=\"$instance\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{instance=\"$instance\"}[5m])) + sum(rate(pg_stat_database_blks_read{instance=\"$instance\"}[5m]))) * 100",
          "legendFormat": "Cache hit ratio",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio",
