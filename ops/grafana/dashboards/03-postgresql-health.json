      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-main"
          },
          "editorMode": "code",
          "expr": "rate(pg_stat_database_xact_rollback{instance=\"$instance\"}[1m])",
          "legendFormat": "Rollbacks/s",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Transactions Rollbacks",
      "type": "timeseries"
