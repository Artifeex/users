      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "enablePagination": true,
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-main"
          },
          "editorMode": "code",
          "expr": "topk(5, sum by (consumergroup, topic) (kafka_consumergroup_lag{topic=~\"$topic\"}))",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Top 5 Consumer Lags",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "Lag"
            }
          }
        }
      ],
      "type": "table"
    }
