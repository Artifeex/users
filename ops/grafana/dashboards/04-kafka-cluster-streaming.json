          "editorMode": "code",
          "expr": "sum by (topic) (rate(kafka_server_brokertopicmetrics_messagesin_total{topic=~\"$topic\", instance=~\"$broker\"}[1m]))",
          "legendFormat": "{{topic}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Messages In Per Second",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "description": "Топ-5 consumer groups с максимальным lag. Позволяет быстро выявить отстающие микросервисы.",
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 10,
        "x": 14,
        "y": 10
